# Host ports
API_PORT=8080
FRONTEND_PORT=4173

# Frontend -> API URL (read by the Vite app; see frontend/src/api.ts)
VITE_API_BASE=http://localhost:8080

# Data/model mount points (inside containers)
RUNS_DIR=/data/runs
WEIGHTS_DIR=/data/weights

# LLM / AI Chatbot (optional — app works without these, chatbot uses mock responses)
OPENROUTER_API_KEY=your_openrouter_key_here
GEMINI_API_KEY=your_gemini_key_here

# --- Auth / security ---

# JWT signing secret (required). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=generate_a_random_value_here

# Set to true in production (HTTPS only)
COOKIE_SECURE=false

# Comma-separated list of origins allowed to send credentials (cookies).
# Dev defaults: Vite dev server (5173) and Vite preview / docker (4173).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173